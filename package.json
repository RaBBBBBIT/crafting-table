{
  "name": "crafting-table",
  "version": "1.0.0",
  "description": "基于Electron的工作台程序，后端用node.js+sqlite实现",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "backend:start": "node backend/server.js",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:dmg": "electron-forge make --platform=darwin --targets=@electron-forge/maker-dmg"
  },
  "keywords": [
    "electron",
    "sqlite",
    "workbench"
  ],
  "author": "于康源",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "^41.0.0"
  }
}
